# ContractGHOST Environment Configuration
# Copy this file to .env and fill in your values

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./contractghost.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/contractghost

CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Optional: AI / LLM Integration ──────────────────────────────────────────
# XAI_API_KEY=xai-...              (Grok – required for Intelligence & Blog features)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...

# ── Optional: File Storage ────────────────────────────────────────────────────
# UPLOAD_DIR=./uploads             (local storage path; swap for S3 in production)

# ── Optional: Auth ────────────────────────────────────────────────────────────
# CLERK_SECRET_KEY=...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=...

# ── AI Governance ────────────────────────────────────────────────────────────
# AI_CONFIDENCE_THRESHOLD=0.65      (suppress outputs below this, default 0.65)
# AI_REVIEW_THRESHOLD=0.5           (flag for human review below this, default 0.5)
# AI_FALLBACK_MODEL=grok-3-mini     (fallback model when primary confidence low)
# AI_MAX_CONTRACT_VALUE_GBP=10000000000  (anomaly flag threshold, default £10bn)
# AI_MAX_CAPEX_GROWTH_PCT=500       (anomaly flag threshold, default 500%)
